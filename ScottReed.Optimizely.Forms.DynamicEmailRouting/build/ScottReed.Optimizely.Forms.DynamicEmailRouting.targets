<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    Copies the protected module ZIP to modules/_protected/ on build.
    Follows the same pattern as EPiServer.Forms.UI.targets.
  -->

  <ItemGroup>
    <DynamicEmailRoutingZip Include="$(MSBuildThisFileDirectory)..\contentFiles\any\any\modules\_protected\**\*.zip" />
  </ItemGroup>

  <Target Name="DynamicEmailRoutingCopyModuleFiles" BeforeTargets="Build">
    <Copy
      SkipUnchangedFiles="true"
      SourceFiles="@(DynamicEmailRoutingZip)"
      DestinationFolder="$(MSBuildProjectDirectory)\modules\_protected\%(RecursiveDir)"
    />
  </Target>

</Project>
